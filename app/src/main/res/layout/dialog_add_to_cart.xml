<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <!-- X 버튼 -->
    <ImageButton
        android:id="@+id/btnDialogClose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="닫기"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 장바구니 아이콘 -->
    <ImageView
        android:id="@+id/ivDialogCart"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_cart"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 메시지 -->
    <TextView
        android:id="@+id/tvDialogMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="장바구니에 상품이 담겼습니다!\n확인하시겠습니까?"
        android:textColor="#111111"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/ivDialogCart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 쇼핑 계속하기 버튼 -->
    <Button
        android:id="@+id/btnContinueShopping"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="8dp"
        android:text="쇼핑 계속하기"
        android:textColor="#111111"
        android:textSize="14sp"
        android:background="@drawable/bg_btn_outline"
        app:layout_constraintTop_toBottomOf="@id/tvDialogMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnGoCart" />

    <!-- 장바구니 확인 버튼 -->
    <Button
        android:id="@+id/btnGoCart"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:text="장바구니 확인"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/bg_btn_filled"
        app:layout_constraintTop_toBottomOf="@id/tvDialogMessage"
        app:layout_constraintStart_toEndOf="@id/btnContinueShopping"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>