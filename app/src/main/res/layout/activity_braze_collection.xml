<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <TextView
            android:id="@+id/textView_braze_test"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Braze 데이터 수집"
            android:textSize="22sp"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 1) Login Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_login"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E6E6E6"
            app:layout_constraintTop_toBottomOf="@id/textView_braze_test"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp">

                <TextView
                    android:id="@+id/text_login_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Login"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_externalId"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/text_login_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/button_login">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_externalId"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="External ID"
                        android:textSize="14sp"
                        android:padding="0dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_login"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="110dp"
                    android:layout_height="48dp"
                    android:text="LOGIN"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toTopOf="@id/textInputLayout_externalId"
                    app:layout_constraintBottom_toBottomOf="@id/textInputLayout_externalId"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2) Event Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_event"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E6E6E6"
            app:layout_constraintTop_toBottomOf="@id/card_login"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp">

                <TextView
                    android:id="@+id/text_event_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Event"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_event"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/text_event_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_event"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Event name (e.g. sample_event)"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Row 1 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_event_property1_name"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="8dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/textInputLayout_event"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/textInputLayout_event_property1_value"
                    app:layout_constraintHorizontal_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_event_property_1"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="Prop 1"
                        android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_event_property1_value"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toTopOf="@id/textInputLayout_event_property1_name"
                    app:layout_constraintBottom_toBottomOf="@id/textInputLayout_event_property1_name"
                    app:layout_constraintStart_toEndOf="@id/textInputLayout_event_property1_name"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_event_property_1_value"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="Value"
                        android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Row 2 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_event_property2_name"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/textInputLayout_event_property1_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/textInputLayout_event_property2_value"
                    app:layout_constraintHorizontal_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_event_property_2"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="Prop 2"
                        android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_event_property2_value"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/textInputLayout_event_property1_value"
                    app:layout_constraintStart_toEndOf="@id/textInputLayout_event_property2_name"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_event_property_2_value"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="Value"
                        android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Row 3 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_event_property3_name"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/textInputLayout_event_property2_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/textInputLayout_event_property3_value"
                    app:layout_constraintHorizontal_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_event_property_3"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="Prop 3"
                        android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_event_property3_value"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/textInputLayout_event_property2_value"
                    app:layout_constraintStart_toEndOf="@id/textInputLayout_event_property3_name"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_event_property_3_value"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="Value"
                        android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_sendEvent"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="SEND EVENT"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/textInputLayout_event_property3_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3) Attribute + Token Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_attr_token"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E6E6E6"
            app:layout_constraintTop_toBottomOf="@id/card_event"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp">

                <TextView
                    android:id="@+id/text_attr_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="User Attribute"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_attribute_key"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="8dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/text_attr_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/textInputLayout_attribute_value"
                    app:layout_constraintHorizontal_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_attribute_key"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Attribute key"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout_attribute_value"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:layout_constraintTop_toBottomOf="@id/text_attr_title"
                    app:layout_constraintStart_toEndOf="@id/textInputLayout_attribute_key"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_attribute_value"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Value"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_saveAttribute"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="SAVE ATTRIBUTE"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/textInputLayout_attribute_key"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/text_token_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Push Token"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/button_saveAttribute"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/textView_token"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_tab_unselected"
                    android:padding="12dp"
                    android:text="로딩 중.."
                    android:textSize="12sp"
                    android:maxLines="4"
                    android:ellipsize="end"
                    android:textIsSelectable="true"
                    app:layout_constraintTop_toBottomOf="@id/text_token_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/button_copyToken"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_copyToken"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="92dp"
                    android:layout_height="0dp"
                    android:text="COPY"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toTopOf="@id/textView_token"
                    app:layout_constraintBottom_toBottomOf="@id/textView_token"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>